  "version": "0.1.0",
  "description": "Local AI-powered merge request review agent",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mr-review": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "review": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["code-review", "ai", "ollama", "git", "merge-request"],
