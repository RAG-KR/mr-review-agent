  },
  "homepage": "https://github.com/RAG-KR/mr-review-agent#readme",
  "bugs": {
    "url": "https://github.com/RAG-KR/mr-review-agent/issues"
  },
  "dependencies": {
    "ollama": "^0.5.9",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
